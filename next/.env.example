# ═══════════════════════════════════════════════════════════════
# Good Things Roasters — 환경변수 템플릿
#
# .env.local 에 복사 후 실제 값을 채운다 (git 추적 대상 아님).
# 키 추가·삭제 시 이 파일도 반드시 동기화할 것.
# 참조: docs/backend-architecture-plan.md §5.4
# ═══════════════════════════════════════════════════════════════

# ── 공개 키 (NEXT_PUBLIC_ — 클라이언트 번들에 포함) ────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# TossPayments 클라이언트 키 (결제위젯 v2)
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# 사업자 연락처 (푸터 등 공개 표시용)
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# ── 서버 전용 키 (절대 NEXT_PUBLIC_ 접두사 금지) ───────────────

# Supabase service_role — RLS 우회, 어드민 API 전용
SUPABASE_SERVICE_ROLE_KEY=

# TossPayments 시크릿 키 — Basic Auth 용도 2가지:
#   1) 결제 승인 API: POST /v1/payments/confirm
#   2) 웹훅 GET 재조회 (카드): GET /v1/payments/{paymentKey} (ADR-002 §3.1)
TOSS_SECRET_KEY=

# 참고: 토스 웹훅 인증은 결제 수단별 하이브리드 (ADR-002).
#   - 카드 (PAYMENT_STATUS_CHANGED): secret 필드 없음 → TOSS_SECRET_KEY 로 GET 재조회.
#   - 가상계좌 (DEPOSIT_CALLBACK): per-payment `secret` 을 payments.webhook_secret 에 저장 →
#     웹훅 본문의 `secret` 과 crypto.timingSafeEqual 대조.
#   → 별도의 웹훅 공통 시크릿(`TOSS_WEBHOOK_SECRET_KEY`) 을 쓰지 않음 (삭제됨, 2026-04-16).

# ── Email (Session 7 인프라) ──────────────────────────────────
# 스펙: docs/email-infrastructure.md

# EMAIL_MODE: live | stub | auto  (기본 auto)
#   auto: NODE_ENV=production → live (RESEND_API_KEY 필수, 없으면 부트 시점 throw)
#         그 외           → RESEND_API_KEY 유무로 자동 판정 (없으면 stub)
#   stub 모드는 Resend 호출 없이 마스킹 콘솔 로그만 남긴다 (로컬·CI 용).
EMAIL_MODE=auto

# Resend API 키 (live 모드 필수).
# 개발·CI 에서는 비워두면 stub 으로 자동 전환.
RESEND_API_KEY=

# 발신 주소. 프로덕션에서는 Session 11 DNS(SPF/DKIM/DMARC) 검증 완료된 도메인 필수.
# 값이 비어있고 stub 모드면 onboarding@resend.dev 로 자동 폴백.
RESEND_FROM_EMAIL=

# Reply-To (선택). 비어있으면 헤더 생략.
RESEND_REPLY_TO=

# 토큰버킷 용량 (req/s, 기본 5).
# Resend 팀당 기본 제한은 5 req/s. Pro 상향 시 조정.
RESEND_RPS=5

# Upstash Redis — rate limiting (Vercel Marketplace 연동 시 자동 주입)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OAuth — Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth — Kakao
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# OAuth — Google (Supabase Auth Dashboard 에서 직접 설정, 서버 직접 사용 X)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth state·nonce 쿠키 서명 시크릿
OAUTH_COOKIE_SECRET=

# 약관 버전 — orders.terms_version 기본값
TERMS_VERSION=

# ── 어드민 API (Session 8-B) ──────────────────────────────────
# x-admin-secret 헤더로 POST /api/admin/* 호출 인증.
# 운영자가 curl/스크립트로 배송 출고 전환 시 사용.
# 미설정 시 모든 어드민 API 거부 (fail-closed).
ADMIN_API_SECRET=
