# ═══════════════════════════════════════════════════════════════
# Good Things Roasters — 환경변수 템플릿
#
# .env.local 에 복사 후 실제 값을 채운다 (git 추적 대상 아님).
# 키 추가·삭제 시 이 파일도 반드시 동기화할 것.
# 참조: docs/backend-architecture-plan.md §5.4
# ═══════════════════════════════════════════════════════════════

# ── 공개 키 (NEXT_PUBLIC_ — 클라이언트 번들에 포함) ────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# TossPayments 클라이언트 키 (결제위젯 v2) — 일반 결제용
NEXT_PUBLIC_TOSS_CLIENT_KEY=
# TossPayments API 개별 연동 클라이언트 키 — 정기배송 빌링(자동결제) 등록용.
# 위젯 키와 별개. 빌링 위젯(requestBillingAuth)은 이 키로 초기화하며,
# 서버 빌링 시크릿(TOSS_API_SECRET_KEY)과 반드시 같은 키 쌍이어야 한다.
NEXT_PUBLIC_TOSS_API_CLIENT_KEY=

# 사업자 정보 (푸터 — 전자상거래법 §13 의무 표시 / build-time 인라인)
NEXT_PUBLIC_BUSINESS_COMPANY_NAME=
NEXT_PUBLIC_BUSINESS_CEO=
NEXT_PUBLIC_BUSINESS_REG_NUMBER=
NEXT_PUBLIC_BUSINESS_ONLINE_NUMBER=
NEXT_PUBLIC_BUSINESS_ADDRESS=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=
# 개인정보관리책임자 (개인정보보호법 §31). 예: "홍길동 (대표) · 010-1234-5678"
NEXT_PUBLIC_BUSINESS_PRIVACY_OFFICER=
# 호스팅 제공자 (전자상거래법 §13 표시 권고). 예: "Vercel Inc."
NEXT_PUBLIC_BUSINESS_HOSTING_PROVIDER=

# Kakao Maps JavaScript SDK 키 (developers.kakao.com 앱 > 플랫폼 > Web 도메인 등록 필요).
# OAuth 의 KAKAO_REST_API_KEY 와 다른 "JavaScript 키" 를 사용한다.
NEXT_PUBLIC_KAKAO_MAP_JS_KEY=

# ── 서버 전용 키 (절대 NEXT_PUBLIC_ 접두사 금지) ───────────────

# Supabase service_role — RLS 우회, 어드민 API 전용
SUPABASE_SERVICE_ROLE_KEY=

# TossPayments 시크릿 키 (결제위젯 연동) — Basic Auth 용도 2가지:
#   1) 결제 승인 API: POST /v1/payments/confirm
#   2) 웹훅 GET 재조회 (카드): GET /v1/payments/{paymentKey} (ADR-002 §3.1)
TOSS_SECRET_KEY=

# TossPayments API 개별 연동 시크릿 키 — 정기배송 빌링(자동결제) 전용.
#   1) 빌링키 발급: POST /v1/billing/authorizations/issue
#   2) 자동결제 승인: POST /v1/billing/{billingKey}
# NEXT_PUBLIC_TOSS_API_CLIENT_KEY 와 같은 키 쌍이어야 한다(불일치 시 토스 거부).
TOSS_API_SECRET_KEY=

# 참고: 토스 웹훅 인증은 결제 수단별 하이브리드 (ADR-002).
#   - 카드 (PAYMENT_STATUS_CHANGED): secret 필드 없음 → TOSS_SECRET_KEY 로 GET 재조회.
#   - 가상계좌 (DEPOSIT_CALLBACK): per-payment `secret` 을 payments.webhook_secret 에 저장 →
#     웹훅 본문의 `secret` 과 crypto.timingSafeEqual 대조.
#   → 별도의 웹훅 공통 시크릿(`TOSS_WEBHOOK_SECRET_KEY`) 을 쓰지 않음 (삭제됨, 2026-04-16).

# ── Email (Session 7 인프라) ──────────────────────────────────
# 스펙: docs/email-infrastructure.md

# EMAIL_MODE: live | stub | auto  (기본 auto)
#   auto: NODE_ENV=production → live (RESEND_API_KEY 필수, 없으면 부트 시점 throw)
#         그 외           → RESEND_API_KEY 유무로 자동 판정 (없으면 stub)
#   stub 모드는 Resend 호출 없이 마스킹 콘솔 로그만 남긴다 (로컬·CI 용).
EMAIL_MODE=auto

# Resend API 키 (live 모드 필수).
# 개발·CI 에서는 비워두면 stub 으로 자동 전환.
RESEND_API_KEY=

# 발신 주소. 프로덕션에서는 Session 11 DNS(SPF/DKIM/DMARC) 검증 완료된 도메인 필수.
# 값이 비어있고 stub 모드면 onboarding@resend.dev 로 자동 폴백.
RESEND_FROM_EMAIL=

# Reply-To (선택). 비어있으면 헤더 생략.
RESEND_REPLY_TO=

# B2B 비즈니스 문의 (/biz-inquiry) 운영자 수신 주소 (S243-A-2).
# 미설정 시 RESEND_REPLY_TO 또는 RESEND_FROM_EMAIL 로 폴백. testing mode 에서는
# Resend 합의 주소만 발송 가능.
BIZ_INQUIRY_TO=

# 토큰버킷 용량 (req/s, 기본 5).
# Resend 팀당 기본 제한은 5 req/s. Pro 상향 시 조정.
RESEND_RPS=5

# Upstash Redis — rate limiting (Vercel Marketplace 연동 시 자동 주입)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Session 8 보안 #1: Carding Rate Limit 활성화 플래그 (docs/payments-security-hardening.md §2).
# - 'true': 카드 거절 5회/10min 초과 시 429 too_many_card_attempts 로 차단.
# - 그 외: dry-run — 카운트만 증분하고 차단 없음 (롤아웃 24h 관측 모드).
CARDING_LIMIT_ENABLED=false

# OAuth — Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth — Kakao
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# OAuth — Google (Supabase Auth Dashboard 에서 직접 설정, 서버 직접 사용 X)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth state·nonce 쿠키 서명 시크릿
OAUTH_COOKIE_SECRET=

# 약관 버전 — orders.terms_version 기본값
TERMS_VERSION=

# ── Sentry — 에러/성능 모니터링 (Session 53) ──────────────────
# DSN: sentry.io → Settings → Projects → {project} → Client Keys (DSN)
# AUTH_TOKEN: sentry.io → Settings → Account → API → Auth Tokens
#   (scopes: project:read, project:write, project:releases, org:read)
# 미설정 시: DSN 없으면 런타임 수집 비활성화, AUTH_TOKEN 없으면 source map 업로드 스킵.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── 어드민 API (Session 8-B · ADR-006) ────────────────────────
# x-admin-secret 헤더로 POST /api/admin/* 호출 인증.
# 운영자가 curl/스크립트로 배송 출고 전환 시 사용 (REST 채널).
# 어드민 UI 는 Server Action + cookie session 사용 (별도 채널).
# 미설정 시 모든 어드민 API 거부 (fail-closed).
ADMIN_API_SECRET=

# ── E2E (Playwright admin · S264-D LOW-C) ─────────────────────
# admin Server Action 흐름 (이미지 업로드/삭제/순서변경) 회귀 검증용.
# globalSetup 에서 본 user_id 로 magic link → admin session storageState 생성.
# Supabase Studio → Authentication → Users → admin 계정의 UID 컬럼 값 사용.
# 미설정 시 admin spec 들이 SKIP — 비admin 스모크는 정상 동작.
E2E_ADMIN_USER_ID=
