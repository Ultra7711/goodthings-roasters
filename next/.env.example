# ═══════════════════════════════════════════════════════════════
# Good Things Roasters — 환경변수 템플릿
#
# .env.local 에 복사 후 실제 값을 채운다 (git 추적 대상 아님).
# 키 추가·삭제 시 이 파일도 반드시 동기화할 것.
# 참조: docs/backend-architecture-plan.md §5.4
# ═══════════════════════════════════════════════════════════════

# ── 공개 키 (NEXT_PUBLIC_ — 클라이언트 번들에 포함) ────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# TossPayments 클라이언트 키 (결제위젯 v2)
NEXT_PUBLIC_TOSS_CLIENT_KEY=

# 사업자 연락처 (푸터 등 공개 표시용)
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=

# ── 서버 전용 키 (절대 NEXT_PUBLIC_ 접두사 금지) ───────────────

# Supabase service_role — RLS 우회, 어드민 API 전용
SUPABASE_SERVICE_ROLE_KEY=

# TossPayments 시크릿 키 — 결제 승인 API (Basic Auth)
TOSS_SECRET_KEY=

# TossPayments 웹훅 서명 검증 키 (HMAC-SHA256)
TOSS_WEBHOOK_SECRET_KEY=

# Resend — 트랜잭셔널 메일 (주문확인·배송안내)
RESEND_API_KEY=

# Upstash Redis — rate limiting (Vercel Marketplace 연동 시 자동 주입)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OAuth — Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth — Kakao
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# OAuth — Google (Supabase Auth Dashboard 에서 직접 설정, 서버 직접 사용 X)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth state·nonce 쿠키 서명 시크릿
OAUTH_COOKIE_SECRET=

# 약관 버전 — orders.terms_version 기본값
TERMS_VERSION=
